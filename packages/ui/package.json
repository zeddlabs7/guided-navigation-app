{
  "name": "@guidenav/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": {
      "import": "./src/styles/index.css",
      "default": "./src/styles/index.css"
    },
    "./assets/*": "./src/assets/*"
  },
  "scripts": {
    "build": "vue-tsc --declaration --emitDeclarationOnly && vite build",
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^1.16.0",
    "@guidenav/types": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.1.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  }
}
