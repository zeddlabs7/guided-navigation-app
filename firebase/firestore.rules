rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection
    // - Owner has full read/write
    // - Anyone can read (courier needs recipient phone number via share link)
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Guidance Sets collection
    // - Any user can read a single doc (courier needs access via share link)
    // - List queries restricted to owner (recipientUserId == auth.uid)
    // - Write restricted to owner
    match /guidanceSets/{guidanceSetId} {
      allow get: if true;
      allow list: if isAuthenticated() && 
        resource.data.recipientUserId == request.auth.uid;
      allow create: if isAuthenticated() && 
        request.resource.data.recipientUserId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
        resource.data.recipientUserId == request.auth.uid;
    }

    // Guidance Steps collection
    // - Anyone can read (courier needs steps via share link)
    // - Write restricted to authenticated users
    match /guidanceSteps/{stepId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // Share Links collection
    match /shareLinks/{shareLinkId} {
      // Anyone with the link can read (for courier access)
      allow read: if true;
      // Anyone can update (courier increments accessCount)
      allow update: if true;
      // Only authenticated users can create/delete their own share links
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Feedback Events collection - append-only for couriers
    match /feedbackEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if false;
    }

    // Analytics Events collection - append-only
    match /analyticsEvents/{eventId} {
      allow read: if isAuthenticated();
      allow create: if true;
      allow update, delete: if false;
    }

    // WhatsApp OTP codes - admin SDK only, no client access
    match /whatsappOtpCodes/{phoneHash} {
      allow read, write: if false;
    }

    // WhatsApp verification sessions - admin SDK only
    match /whatsappVerifySessions/{sessionId} {
      allow read, write: if false;
    }

    // WhatsApp verification token lookups - admin SDK only
    match /whatsappVerifyTokens/{tokenHash} {
      allow read, write: if false;
    }
  }
}
