rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // TEMPORARY: Open rules for development without auth
    // TODO: Revert to auth-based rules before production launch
    // ============================================================

    // Guidance Sets collection
    match /guidanceSets/{guidanceSetId} {
      allow read, write: if true;
    }

    // Guidance Steps collection
    match /guidanceSteps/{stepId} {
      allow read, write: if true;
    }

    // Share Links collection
    match /shareLinks/{shareLinkId} {
      allow read: if true;
      allow write: if true;
    }

    // Feedback Events collection
    match /feedbackEvents/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Analytics Events collection
    match /analyticsEvents/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
