rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Guidance step images
    match /guidanceSets/{guidanceSetId}/steps/{stepId}/{fileName} {
      // Public read access for MVP (couriers access without auth)
      allow read: if true;
      
      // Only authenticated users can upload
      allow write: if request.auth != null;
    }

    // Deny access to all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
