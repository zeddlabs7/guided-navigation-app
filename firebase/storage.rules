rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ============================================================
    // TEMPORARY: Open rules for development without auth
    // TODO: Revert to auth-based rules before production launch
    // ============================================================

    // Guidance step images
    match /guidanceSets/{guidanceSetId}/steps/{stepId}/{fileName} {
      allow read: if true;
      allow write: if true;
    }

    // Allow all paths temporarily for development
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
