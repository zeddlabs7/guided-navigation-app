# Courier app URL (for share links)
EXPO_PUBLIC_COURIER_APP_URL=https://guided-navigation-app-courier.netlify.app

# Google Maps API key
# Required APIs: Maps SDK for iOS, Maps SDK for Android, Places API (New), Geocoding API
# 1. Go to https://console.cloud.google.com/apis/library
# 2. Enable: Maps SDK for iOS, Maps SDK for Android, Places API (New), Geocoding API
# 3. Go to https://console.cloud.google.com/apis/credentials
# 4. Create or edit an API key restricted to the above APIs
# 5. Paste the key below
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# For EAS builds, run these from apps/mobile (not the monorepo root):
#   cd apps/mobile
#   eas env:create --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY --value "YOUR_KEY" --environment preview --visibility plaintext
#   eas env:create --name EXPO_PUBLIC_GOOGLE_MAPS_API_KEY --value "YOUR_KEY" --environment production --visibility plaintext
# Then rebuild: npx eas build --platform android --profile preview
